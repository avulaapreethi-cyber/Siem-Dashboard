1. App.py
from flask import Flask, jsonify, render_template, request, redirect, session
import sqlite3

app = Flask(__name__)
app.secret_key = "secret123"


USER = {"username": "admin", "password": "admin"}

def detect_threat(attack):
    if attack == "DoS":
        return "High"
    elif attack == "Probe":
        return "Medium"
    else:
        return "Low"
@app.route("/login", methods=["GET", "POST"])
def login():
    if request.method == "POST":
        username = request.form["username"]
        password = request.form["password"]

        if username == USER["username"] and password == USER["password"]:
            session["logged_in"] = True
            return redirect("/")
    
    return render_template("login.html")

@app.route("/")
def home():
    if not session.get("logged_in"):
        return redirect("/login")
    return render_template("index.html")


@app.route("/logs")
def get_logs():
    conn = sqlite3.connect("siem.db")
    cursor = conn.cursor()

    cursor.execute("SELECT time, ip, attack FROM logs ORDER BY id DESC LIMIT 50")
    rows = cursor.fetchall()

    data = []
    for row in rows:
        data.append({
            "time": row[0],
            "ip": row[1],
            "attack": row[2],
            "severity": detect_threat(row[2])
        })

    conn.close()
    return jsonify(data)


@app.route("/logout")
def logout():
    session.clear()
    return redirect("/login")

if __name__ == "__main__":
    app.run(debug=True)

2. Log_generator.py
import random
import sqlite3
import time
from datetime import datetime

ATTACKS = ["Normal", "DoS", "Probe", "R2L", "U2R"]

def generate_log():
    return {
        "time": str(datetime.now()),
        "ip": f"192.168.1.{random.randint(1,255)}",
        "attack": random.choice(ATTACKS)
    }

def save_log(log):
    conn = sqlite3.connect("siem.db")
    cursor = conn.cursor()

    cursor.execute(
        "INSERT INTO logs (time, ip, attack) VALUES (?, ?, ?)",
        (log["time"], log["ip"], log["attack"])
    )

    conn.commit()
    conn.close()

while True:
    log = generate_log()
    save_log(log)
    print("Generated:", log)
    time.sleep(2)

